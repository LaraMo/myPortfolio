{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["oxc", "unicorn", "typescript", "react", "nextjs", "vitest"],
  "ignorePatterns": [".next/**", "node_modules/**", "coverage/**"],
  "env": {
    "builtin": true,
    "browser": true,
    "node": true
  },
  "settings": {
    "react": {
      "version": "19.2"
    }
  }
}
